BASE_HOOK=              # SentryHook on Base Sepolia
UNICHAIN_ORACLE=        # ReputationOracle on Unichain Sepolia
BASE_ORACLE=            # ReputationOracle on Base Sepolia
AGGREGATOR=             # ReputationAggregator on Reactive Kopli
SCHEDULER=              # RedistributionScheduler on Reactive Kopli

# Chain IDs
UNICHAIN_CHAIN_ID=1301
BASE_CHAIN_ID=84532

# Reactive Network
REACTIVE_SUBSCRIPTION_SERVICE=  # Provided by Reactive Network on Kopli

# Optional: existing oracle (skips deployment if set)
REPUTATION_ORACLE=
