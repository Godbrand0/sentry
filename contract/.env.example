# Deployer
DEPLOYER=0x...
PRIVATE_KEY=0x...

# Target chain RPC URLs
UNICHAIN_RPC_URL=https://sepolia.unichain.org
BASE_RPC_URL=https://sepolia.base.org
REACTIVE_RPC_URL=https://kopli-rpc.reactive.network

# Deployed contract addresses (fill after deployment)
